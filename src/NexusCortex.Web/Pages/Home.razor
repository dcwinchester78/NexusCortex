@page "/"
@using NexusCortex.Web.Services
@using NexusCortex.Application.Dtos
@using NexusCortex.Domain
@inject IDashboardApiClient DashboardClient
@inject INodeApiClient NodeClient

<PageTitle>Dashboard - Nexus Cortex</PageTitle>

<MudText Typo="Typo.h3" Class="mb-6">Command Center</MudText>

@if (_isLoading)
{
    <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
}
else if (_stagnantNodes != null && _stagnantNodes.Any())
{
    <MudAlert Severity="Severity.Warning" Class="mb-6">
        You have @_stagnantNodes.Count() stagnant areas/projects that need attention!
    </MudAlert>
}

<MudGrid>
    <MudItem xs="12" md="4">
        <MudCard Elevation="3" Class="h-100">
            <MudCardHeader>
                <CardHeaderContent>
                    <MudText Typo="Typo.h5" Color="Color.Primary">Next Best Actions</MudText>
                </CardHeaderContent>
                <CardHeaderActions>
                    <MudIconButton Icon="@Icons.Material.Filled.Bolt" Color="Color.Primary" />
                </CardHeaderActions>
            </MudCardHeader>
            <MudCardContent>
                @if (_nextBestActions == null || !_nextBestActions.Any())
                {
                    <MudText Typo="Typo.body2" Color="Color.Surface">No pending actions found. Time to plan!</MudText>
                }
                else
                {
                    <MudList T="Node" Dense="true">
                        @foreach (var action in _nextBestActions)
                        {
                            <MudListItem T="Node" Icon="@Icons.Material.Filled.CheckBoxOutlineBlank">
                                <MudText Typo="Typo.body1">@action.Name</MudText>
                                @if (action.DueDate.HasValue)
                                {
                                    <MudText Typo="Typo.caption" Color="Color.Error">
                                        Due: @action.DueDate.Value.ToShortDateString()
                                    </MudText>
                                }
                            </MudListItem>
                        }
                    </MudList>
                }
            </MudCardContent>
        </MudCard>
    </MudItem>

    <MudItem xs="12" md="8">
        <MudText Typo="Typo.h5" Class="mb-4">Areas of Focus</MudText>
        <MudGrid>
            @if (_dashboard?.Areas == null || !_dashboard.Areas.Any())
            {
                <MudItem xs="12">
                    <MudText Typo="Typo.body1">No Areas defined yet.</MudText>
                </MudItem>
            }
            else
            {
                @foreach (var area in _dashboard.Areas)
                {
                    <MudItem xs="12" sm="6">
                        <MudCard Elevation="2">
                            <MudCardHeader>
                                <CardHeaderContent>
                                    <MudText Typo="Typo.h6">@area.Name</MudText>
                                </CardHeaderContent>
                            </MudCardHeader>
                            <MudCardContent>
                                <MudText Typo="Typo.body2" Class="mb-1">Momentum</MudText>
                                <MudProgressLinear Color="Color.Info" Value="@((double)area.MomentumScore)" Max="100" Class="my-2" />
                                <MudText Typo="Typo.caption" Align="Align.End">Score: @area.MomentumScore</MudText>
                            </MudCardContent>
                            <MudCardActions>
                                <MudButton Variant="Variant.Text" Color="Color.Primary" Href="@($"/nodes/{area.Id}")">View Details</MudButton>
                            </MudCardActions>
                        </MudCard>
                    </MudItem>
                }
            }
        </MudGrid>
    </MudItem>
</MudGrid>

@code {
    private bool _isLoading = true;
    private DashboardDto? _dashboard;
    private IEnumerable<Node>? _nextBestActions;
    private IEnumerable<Node>? _stagnantNodes;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var dashboardTask = DashboardClient.GetDashboardAsync();
            var actionsTask = NodeClient.GetNextBestActionsAsync(5);
            var stagnantTask = DashboardClient.GetStagnantNodesAsync(7);

            await Task.WhenAll(dashboardTask, actionsTask, stagnantTask);

            _dashboard = await dashboardTask;
            _nextBestActions = await actionsTask;
            _stagnantNodes = await stagnantTask;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading dashboard: {ex.Message}");
        }
        finally
        {
            _isLoading = false;
        }
    }
}
